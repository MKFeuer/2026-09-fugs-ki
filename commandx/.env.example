# CIMgate.Connect API – Konfiguration
# Kopieren nach .env und Werte eintragen

# Host und Port des CIMgate-Servers
COMMANDX_HOST=

# Security-Header (Name und Wert aus den CIMgate-Einstellungen)
COMMANDX_SECURITY_HEADER_NAME=CX5-Security-Token
COMMANDX_SECURITY_HEADER_VALUE=

# Statischer Bearer-Token
COMMANDX_BEARER_TOKEN=

# SSL-Zertifikat prüfen (false bei selbst-signierten Zertifikaten)
COMMANDX_VERIFY_SSL=false

# User-Agent Header
COMMANDX_USER_AGENT=insomnia/12.5.0


