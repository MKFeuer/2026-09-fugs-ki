{
  "name": "fugs-ki-agent",
  "description": "Chat MVP: AI SDK v6 + Gemma 4 + MCP",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun-tasks dev:frontend ::: dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "bun --watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@fontsource-variable/google-sans-flex": "^5.2.2",
    "ai": "^6.0.0",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@modelcontextprotocol/server-filesystem": "^2025.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-tasks": "^0.1.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "8.0.3"
  }
}
