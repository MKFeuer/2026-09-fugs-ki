{
  "name": "fugs-ki-agentv2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun-tasks dev:frontend ::: dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "bun --watch server/index.ts",
    "build": "vue-tsc -p tsconfig.app.json --noEmit && vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/google-sans-flex": "^5.2.2",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "leaflet": "^1.9.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "bun-tasks": "^0.1.2",
    "bun-types": "^1.3.12",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vue-tsc": "^3.1.4"
  }
}
